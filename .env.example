# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Option A: Local model via Ollama (default, no cost) ─────────────────────
# 1. Install Ollama: https://ollama.com/download
# 2. Pull a model:  ollama pull qwen2.5-coder:7b
# 3. Ollama listens on port 11434 automatically.
#
# Inside Docker:  host.docker.internal resolves to your Windows host.
# Outside Docker: use localhost instead.
LLM_API_KEY=ollama
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=qwen3-coder-next:latest

# ── Option B: Kimi K2 via Moonshot AI (remote, requires account) ──────────────
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=kimi-k2-0711-preview

# ── Other OpenAI-compatible options ───────────────────────────────────────────
# OpenAI:       LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o
# Groq:         LLM_BASE_URL=https://api.groq.com/openai/v1   LLM_MODEL=llama-3.3-70b-versatile
# LM Studio:    LLM_BASE_URL=http://localhost:1234/v1   LLM_MODEL=<loaded-model>

# ── Agent personality (used by individual agent containers, not orchestrator) ──
# Supported: code_reviewer | planner | researcher | debugger | architect | default
AGENT_ROLE=default

# ── Model tuning ───────────────────────────────────────────────────────────────
MAX_TOKENS=4096
TEMPERATURE=0.6
AGENT_TIMEOUT=120

# ── CLI ────────────────────────────────────────────────────────────────────────
# Set when using hive.exe if not localhost (e.g. minikube NodePort IP)
# HIVE_URL=http://192.168.49.2:30800
# HIVE_TIMEOUT=180