# ┌─────────────────────────────────────────────────────┐
# │  Hive — Environment Configuration                  │
# └─────────────────────────────────────────────────────┘
# Copy this file to .env and customise as needed.

# ── Option A: Local model via Ollama (default, no cost) ─────────────────────
LLM_API_KEY=ollama
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=qwen2.5-coder:7b

# ── Option B: Kimi K2 via Moonshot AI ──────────────────────────────────────
# LLM_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=kimi-k2-0711-preview

# ── Option C: OpenAI ──────────────────────────────────────────────────────
# LLM_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# ── Option D: Groq ────────────────────────────────────────────────────────
# LLM_API_KEY=gsk_your-key-here
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-70b-versatile

# ── Option E: LM Studio ──────────────────────────────────────────────────
# LLM_API_KEY=lm-studio
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=your-model-name

# ── Agent personality ──────────────────────────────────────────────────────
# Supported: code_reviewer | planner | researcher | debugger | architect | default
AGENT_ROLE=default

# ── Model tuning ──────────────────────────────────────────────────────────
MAX_TOKENS=4096
TEMPERATURE=0.6
AGENT_TIMEOUT=120

# ── CLI settings ──────────────────────────────────────────────────────────
# HIVE_URL=http://localhost:30800
# OLLAMA_HOST=http://localhost:11434